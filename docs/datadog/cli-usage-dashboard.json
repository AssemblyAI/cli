                    {
                      "name": "total",
                      "data_source": "logs",
                      "search": {
                        "query": "source:aai-cli"
                      },
                      "indexes": [
                        "*"
                      ],
                      "compute": {
                        "aggregation": "count"
                      },
                      "group_by": []
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "errors / total * 100"
                    }
                  ],
                  "conditional_formats": [
                    {
                      "comparator": "<",
                      "value": 2,
                      "palette": "white_on_green"
                    },
                    {
                      "comparator": "<",
                      "value": 5,
                      "palette": "white_on_yellow"
                    },
                    {
                      "comparator": ">=",
